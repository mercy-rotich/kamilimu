# Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# The USSD app itself (src/app.py) needs no external API keys — it's
# fully self-contained and reads mock data from src/schools.json.

# Required only for parse_audit.py (audit PDF -> DeepSeek extraction):
# get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-key-here

# Optional: override the local Flask port (default 5000)
PORT=5000
